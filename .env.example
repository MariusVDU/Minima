# MySQL Configuration
# Kopijuokite šį failą į .env ir nustatykite savo duomenis

# MySQL vartotojas (numatyta: root)
MYSQL_USERNAME=root

# MySQL slaptažodis - BŪTINA PAKEISTI!
MYSQL_PASSWORD=root

# MySQL serverio vieta (localhost vietiniam paleidimui)
MYSQL_HOST=localhost
MYSQL_PORT=3306

# Duomenų bazės pavadinimas
MYSQL_DATABASE=minima

# Naudojimas:
# 1. Kopijuokite: cp .env.example .env
# 2. Redaguokite .env savo duomenimis (MYSQL_PASSWORD!)
# 3. Windows: $env:MYSQL_PASSWORD="jusu_slaptazodis"
# 4. Linux/Mac: export MYSQL_PASSWORD="jusu_slaptazodis"
# 5. Vėliau: docker-compose up --build
